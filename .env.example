# =============================================================================
# JobSeeker — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development. In production, set
# these in your hosting provider (Vercel → Project Settings → Environment
# Variables). Never commit secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------

# Canonical origin of the running app. Used to build OAuth callback URLs,
# magic-link redirects, Lemon Squeezy return URLs, etc. No trailing slash.
#   dev:  http://localhost:3000
#   prod: https://jobseeker.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Master key used by lib/crypto.ts to encrypt secrets at rest
# (BYO API keys, SMTP App Passwords, etc). MUST decode to 32 bytes.
# Generate with:  openssl rand -base64 32
APP_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# Dashboard → Project Settings → API
#   URL                    → NEXT_PUBLIC_SUPABASE_URL
#   Project API Keys · anon public         → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Project API Keys · service_role secret → SUPABASE_SERVICE_ROLE_KEY
# The service-role key bypasses RLS — NEVER expose it to the browser.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# AI — "ours" key (server-side default for Pro / Elite)
# -----------------------------------------------------------------------------
# Gemini Flash is our default paid-tier model. BYO users bring their own key
# via the UI; this key is only used when configs.ai_key_mode = 'ours'.
GEMINI_API_KEY=

# Optional: override the default model name (cost/quality tuning).
GEMINI_MODEL=gemini-1.5-flash


# -----------------------------------------------------------------------------
# PAYMENTS — Lemon Squeezy
# -----------------------------------------------------------------------------
# Dashboard → Settings → API          → LEMON_SQUEEZY_API_KEY
# Dashboard → Store settings → Webhooks → create endpoint → LEMON_SQUEEZY_WEBHOOK_SECRET
# Product variant IDs come from: Dashboard → Products → variant → URL (numeric id)

LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_PRO=
LEMON_SQUEEZY_VARIANT_ELITE=


# -----------------------------------------------------------------------------
# SYSTEM EMAIL — Resend (daily summaries, transactional)
# -----------------------------------------------------------------------------
# Dashboard → API Keys → Create   → RESEND_API_KEY
# Dashboard → Domains  → add DNS records (SPF / DKIM) for the sending domain.
RESEND_API_KEY=
RESEND_FROM=JobSeeker <noreply@jobseeker.app>


# -----------------------------------------------------------------------------
# JOB SOURCES
# -----------------------------------------------------------------------------
# Adzuna: free dev tier. https://developer.adzuna.com  → App ID + App Key.
# RemoteOK / Remotive / WeWorkRemotely: public JSON feeds, no key needed.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=


# -----------------------------------------------------------------------------
# CRON / AUTOMATION
# -----------------------------------------------------------------------------
# Shared secret required by /api/cron/* routes so only Vercel Cron (or us,
# when poking manually with curl) can trigger them. Generate with:
#   openssl rand -hex 32
CRON_SECRET=
